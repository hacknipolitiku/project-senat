---
import { DISTRICTS, DISTRICT_COORDS } from '../lib/data';

const base = import.meta.env.BASE_URL;

// Czech Republic outline path (approximate, clockwise from western tip)
const outline = `
  M 60,220
  L 68,190 L 75,162 L 95,130 L 120,108 L 148,95
  L 185,83 L 228,76 L 270,73 L 310,78 L 355,82
  L 390,88 L 425,92 L 460,90 L 500,96 L 540,108
  L 580,118 L 618,130 L 658,148 L 695,168 L 728,190
  L 748,215 L 753,245 L 748,272 L 735,298 L 718,318
  L 700,335 L 678,350 L 650,362 L 620,372 L 590,378
  L 558,382 L 524,388 L 490,396 L 455,404 L 418,408
  L 380,410 L 342,408 L 308,404 L 272,396 L 238,385
  L 208,370 L 178,352 L 152,330 L 128,305 L 105,278
  L 85,255 L 68,240 Z
`.trim();
---

<div class="w-full overflow-x-auto">
  <svg
    viewBox="0 0 800 480"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-4xl mx-auto"
    aria-label="Mapa senátních obvodů ČR 2026"
  >
    <!-- Country fill -->
    <path d={outline} fill="#f5f5f4" stroke="#d6d3d1" stroke-width="1.5" />

    <!-- District markers -->
    {Object.entries(DISTRICTS).map(([idStr]) => {
      const id = parseInt(idStr);
      const coords = DISTRICT_COORDS[id];
      const name = DISTRICTS[id];
      if (!coords) return null;
      const href = `${base}obvod/${id}/`;
      return (
        <a href={href} aria-label={`Obvod ${id} – ${name}`}>
          <circle
            cx={coords.x}
            cy={coords.y}
            r="13"
            fill="white"
            stroke="#374151"
            stroke-width="1.5"
            class="hover:fill-gray-100 transition-colors cursor-pointer"
          />
          <text
            x={coords.x}
            y={coords.y + 4}
            text-anchor="middle"
            font-size="9"
            font-family="system-ui, sans-serif"
            font-weight="600"
            fill="#111827"
            pointer-events="none"
          >
            {id}
          </text>
        </a>
      );
    })}
  </svg>
</div>

<!-- Legend -->
<div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 text-sm">
  {Object.entries(DISTRICTS).map(([idStr, name]) => {
    const id = parseInt(idStr);
    return (
      <a
        href={`${base}obvod/${id}/`}
        class="flex items-center gap-2 px-3 py-1.5 rounded border border-gray-200 hover:bg-gray-50 transition-colors"
      >
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full border border-gray-400 text-xs font-semibold text-gray-700 shrink-0">
          {id}
        </span>
        <span class="text-gray-700 truncate">{name}</span>
      </a>
    );
  })}
</div>
