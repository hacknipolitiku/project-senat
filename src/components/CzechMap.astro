---
import { getCollection } from "astro:content";
import { getProcessedMapSvg } from "../lib/map";
import { getDistrictUrl } from "../lib/links";

const svg = getProcessedMapSvg();
const [allCandidates, districtEntries] = await Promise.all([
  getCollection("candidates"),
  getCollection("districts"),
]);
const totalCandidates = allCandidates.length;
const sortedDistricts = districtEntries.sort((a, b) => a.data.id - b.data.id);
---

<div class="w-full">
  <div class="w-full rounded overflow-hidden">
    <Fragment set:html={svg} />
  </div>

  <!-- Legend -->
  <p class="text-gray-500 mt-12">
    {sortedDistricts.length} obvodů · {totalCandidates} kandidátů
  </p>
  <div
    class="mt-3 grid grid-flow-col auto-cols-fr grid-rows-100 sm:grid-rows-14 md:grid-rows-9 lg:grid-rows-7 gap-2 text-sm"
  >
    {
      sortedDistricts.map((d) => (
        <a
          href={getDistrictUrl(d.data.name)}
          class="flex items-center gap-2 px-3 py-2 rounded border transition-colors hover:bg-blue-50"
          style="border-color: #9394D2;"
        >
          <span
            class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold shrink-0"
            style="background-color: #2a2b66; color: white;"
          >
            {d.data.id}
          </span>
          <span style="color: #2a2b66;" class="truncate">
            {d.data.name}
          </span>
          <span class="ml-auto w-2 h-2 border-t-2 border-l-2 transform rotate-135 border-gray-800" />
        </a>
      ))
    }
  </div>
</div>

<style>
  :global(.s-active) {
    cursor: pointer;
    transition: fill 0.2s ease;
    fill: #5246ef !important;

    /* stroke: black; */
    /* stroke-width: 10px; */
  }

  /* It would be nicer to do this differently */
  :global(text) {
    font-family: var(--font-sans) !important;
    fill: #2a2b66;
  }
  :global(.s-active:hover) {
    fill: #93c5fd !important;
  }
</style>

<script>
  document.querySelectorAll<SVGElement>(".s-active").forEach((el) => {
    el.addEventListener("click", () => {
      const href = el.dataset.href;
      if (href) location.href = href;
    });
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        const href = el.dataset.href;
        if (href) location.href = href;
      }
    });
    el.setAttribute("tabindex", "0");
    el.setAttribute("role", "link");
  });
</script>
