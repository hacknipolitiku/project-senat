const activeIds = new Set(Object.keys(DISTRICTS).map(Number));
---

<div class="w-full">
  <!-- Map container with overlaid SVG for clickable districts -->
  <div class="relative w-full">
    <img
      src={`${base}senate-map.svg`}
      alt="Mapa senátních obvodů České republiky"
      class="w-full h-auto block"
    />
    <!-- Overlay SVG matching the map's coordinate space -->
    <svg
      viewBox="0 0 3845.2656 2990.762"
      xmlns="http://www.w3.org/2000/svg"
      class="absolute inset-0 w-full h-full"
      aria-label="Mapa senátních obvodů ČR 2026"
    >
      {Object.entries(LABEL_COORDS).map(([idStr, coords]) => {
        const id = parseInt(idStr);
        const isActive = activeIds.has(id);
        if (!isActive) return null;
        const name = DISTRICTS[id];
        const r = 95;
        return (
          <a href={`${base}obvod/${id}/`} aria-label={`Obvod ${id} – ${name}`}>
            <circle
              cx={coords.x}
              cy={coords.y}
              r={r}
              fill="white"
              fill-opacity="0.85"
              stroke="#374151"
              stroke-width="12"
              class="hover:fill-gray-100 cursor-pointer transition-colors"
            />
            <text
              x={coords.x}
              y={coords.y + 18}
              text-anchor="middle"
              font-size="80"
              font-family="system-ui, sans-serif"
              font-weight="700"
              fill="#111827"
              pointer-events="none"
            >
              {id}
            </text>
          </a>
        );
      })}
    </svg>
  </div>

  <!-- Legend -->
  <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 text-sm">
    {Object.entries(DISTRICTS).map(([idStr, name]) => {
      const id = parseInt(idStr);
      return (
        <a
          href={`${base}obvod/${id}/`}
          class="flex items-center gap-2 px-3 py-1.5 rounded border border-gray-200 hover:bg-gray-50 transition-colors"
        >
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full border border-gray-400 text-xs font-semibold text-gray-700 shrink-0">
            {id}
          </span>
          <span class="text-gray-700 truncate">{name}</span>
        </a>
      );
    })}
  </div>
</div>
