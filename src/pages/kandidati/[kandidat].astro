---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { formatCzechName, getPartyLogoFiles } from "../../lib/data";
import { getDistrictUrl, getPartyLogoUrl } from "../../lib/links";

export async function getStaticPaths() {
  const [candidateEntries, districtEntries, hlidacStatuEntries] =
    await Promise.all([
      getCollection("candidates"),
      getCollection("districts"),
      getCollection("hlidac-statu"),
    ]);
  return candidateEntries.map((entry) => {
    const districtCandidates = candidateEntries.filter(
      (e) => e.data.districtId === entry.data.districtId,
    );
    const district = districtEntries.find(
      (d) => d.data.id === entry.data.districtId,
    );
    const hlidacStatu = entry.data.hlidacStatuOsobaId
      ? (hlidacStatuEntries.find(
          (h) => h.id === entry.data.hlidacStatuOsobaId,
        ) ?? null)
      : null;
    return {
      params: { kandidat: entry.id },
      props: { entry, districtCandidates, district, hlidacStatu },
    };
  });
}

const { entry, district, hlidacStatu } = Astro.props;
const { Content } = await render(entry);

const districtId = entry.data.districtId;
const districtName = district?.data.name ?? "";
const districtUrl = getDistrictUrl(district?.data.slug ?? "");

const displayName = formatCzechName(entry.data.name);
const birthYear = 2026 - entry.data.age;
const partyLogos = getPartyLogoFiles(entry.data.electoralParty);

const osobaId = entry.data.hlidacStatuOsobaId;
const hlidacStatuProfileUrl = osobaId
  ? `https://www.hlidacstatu.cz/osoba/${osobaId}`
  : null;

function formatCzk(amount: number): string {
  return amount.toLocaleString("cs-CZ") + " Kč";
}

function formatDateRange(item: {
  datumOd?: Date | null;
  datumDo?: Date | null;
}): string {
  if (item.datumOd)
    return `${item.datumOd.getFullYear()} - ${item.datumDo ? item.datumDo.getFullYear() : "dosud"}`;
  if (item.datumDo) return `do ${item.datumDo.getFullYear()}`;
  return "";
}
---

<Layout
  title={displayName}
  description={`${displayName} – kandidát v obvodu ${districtId} ${districtName}`}
>
  <nav class="text-sm mb-6">
    <a
      href={districtUrl}
      class="font-semibold transition-opacity hover:opacity-70"
      style="color: #2a2b66;">← Přehled kandidátů</a
    >
  </nav>

  <div class="mb-8">
    <div class="flex items-start gap-4">
      <div class="shrink-0 mt-1">
        <div
          class="w-14 h-14 rounded-full flex items-center justify-center text-xl font-bold"
          style="background-color: #2a2b66; color: white; border: 3px solid #fa1a5b;"
        >
          {entry.data.candidateNumber}
        </div>
      </div>
      <div>
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="text-3xl font-bold text-gray-900">{displayName}</h1>
        </div>
        <p class="text-gray-500 mt-1">Obvod {districtId} · {districtName}</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <section class="rounded-lg p-5" style="border: 1px solid #2a2b6630;">
      <h2
        class="text-xs font-semibold uppercase tracking-wide mb-4"
        style="color: #2a2b66;"
      >
        Základní informace
      </h2>
      <dl class="space-y-3">
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Věk</dt>
          <dd class="text-sm font-medium text-gray-900">
            *{birthYear} ({entry.data.age} let)
          </dd>
        </div>
        <div class="flex justify-between gap-4 items-center">
          <dt class="text-sm text-gray-500">Volební strana</dt>
          <dd
            class="text-sm font-medium text-gray-900 text-right flex items-center gap-2 flex-wrap justify-end"
          >
            {
              partyLogos.length > 0
                ? partyLogos.map((logo) => (
                    <img
                      src={getPartyLogoUrl(logo)}
                      alt={logo.replace(".svg", "")}
                      class="h-6 w-auto"
                    />
                  ))
                : entry.data.electoralParty
            }
          </dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Politická příslušnost</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">
            {entry.data.politicalAffiliation}
          </dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Povolání</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">
            {entry.data.occupation}
          </dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Bydliště</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">
            {entry.data.residence}
          </dd>
        </div>
      </dl>
    </section>

    <section
      class="rounded-lg p-5 pulse-card"
      style="border: 1px solid #2a2b6630;"
    >
      <h2
        class="text-xl font-semibold uppercase tracking-wide mb-4"
        style="color: #2a2b66;"
      >
        Jak se zapojit
      </h2>
      <div class="profile-content prose prose-sm max-w-none text-gray-700 mt-6">
        <Content />
      </div>
    </section>
  </div>

  {
    hlidacStatu && (
      <section class="rounded-lg p-5 mb-8" style="border: 1px solid #2a2b6630;">
        <div class="flex items-center justify-between mb-6">
          <h2
            class="text-xs font-semibold uppercase tracking-wide"
            style="color: #2a2b66;"
          >
            Hlídač státu
          </h2>
          {hlidacStatuProfileUrl && (
            <a
              href={hlidacStatuProfileUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs transition-opacity hover:opacity-70"
              style="color: #2a2b66;"
            >
              Profil na Hlídači státu ↗
            </a>
          )}
        </div>

        {hlidacStatu.data.udalosti.length > 0 &&
          (() => {
            const byDate = (
              a: { datumOd?: Date | null },
              b: { datumOd?: Date | null },
            ) => (b.datumOd?.getTime() ?? 0) - (a.datumOd?.getTime() ?? 0);
            const active = hlidacStatu.data.udalosti
              .filter((u) => !u.datumDo)
              .sort(byDate);
            const past = hlidacStatu.data.udalosti
              .filter((u) => u.datumDo)
              .sort(byDate);

            const renderList = (items: typeof active) => (
              <ul class="space-y-3">
                {items.map((u) => (
                  <li class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <div class="flex items-center gap-3">
                      <div class="text-sm text-gray-400 shrink-0 pt-2 min-w-25">
                        {formatDateRange(u)}
                      </div>
                      <div>
                        <span class="text-xs font-medium text-gray-500 m-1">
                          {u.typ}
                        </span>
                        <span class="text-sm text-gray-900 m-1">
                          {u.organizace}
                        </span>
                        <span class="text-xs text-gray-500 m-1">{u.role}</span>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            );

            return (
              <>
                {active.length > 0 && (
                  <div class="mb-6">
                    <h3 class="text-sm font-semibold text-gray-700 mb-3">
                      Funkce
                    </h3>
                    {renderList(active)}
                  </div>
                )}
                {past.length > 0 && (
                  <div>
                    <h3 class="text-sm font-semibold text-gray-700 mb-3">
                      Minulé funkce
                    </h3>
                    {renderList(past)}
                  </div>
                )}
              </>
            );
          })()}

        {hlidacStatu.data.sponzoring.length > 0 && (
          <div class="mt-6">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Sponzoring</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left py-2 pr-4 text-gray-500 font-medium">
                      Datum
                    </th>
                    <th class="text-left py-2 pr-4 text-gray-500 font-medium">
                      Organizace
                    </th>
                    <th class="text-right py-2 pr-4 text-gray-500 font-medium">
                      Částka
                    </th>
                    <th class="text-left py-2 text-gray-500 font-medium">
                      Typ
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {[...hlidacStatu.data.sponzoring]
                    .sort((a, b) => a.datumOd.getTime() - b.datumOd.getTime())
                    .map((s) => (
                      <tr class="border-b border-gray-100">
                        <td class="py-2 pr-4 text-gray-400 font-mono text-xs">
                          {s.datumOd.getFullYear()}
                        </td>
                        <td class="py-2 pr-4 text-gray-900">{s.organizace}</td>
                        <td class="py-2 pr-4 text-gray-900 text-right font-mono">
                          {formatCzk(s.castka)}
                        </td>
                        <td class="py-2 text-gray-600">{s.typ}</td>
                      </tr>
                    ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>
    )
  }

  <!-- The back button on bottom is only visible on mobile -->
  <nav class="text-sm mb-6 mt-12 sm:hidden">
    <a
      href={districtUrl}
      class="font-semibold transition-opacity hover:opacity-70"
      style="color: #2a2b66;">← Přehled kandidátů</a
    >
  </nav>
</Layout>

<style>
  @keyframes pulse-border {
    0%,
    100% {
      box-shadow:
        0 0 0 0 rgba(99, 102, 241, 0.7),
        0 0 0 0 rgba(99, 102, 241, 0.4);
    }
    50% {
      box-shadow:
        0 0 0 8px rgba(99, 102, 241, 0.2),
        0 0 0 16px rgba(99, 102, 241, 0);
    }
  }

  .pulse-card {
    border: 2px solid #6366f1;
    border-radius: 0.75rem;
    animation: pulse-border 2s ease-in-out infinite;
    padding: 1.25rem 1.5rem;
  }
</style>
