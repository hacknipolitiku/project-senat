---
import Layout from '../../../layouts/Layout.astro';
import { getCandidates, getDistrict, DISTRICTS } from '../../../lib/data';

export async function getStaticPaths() {
  return getCandidates().map((c) => ({
    params: { obvod: String(c.districtId), kandidat: String(c.candidateNumber) },
  }));
}

const { obvod, kandidat } = Astro.params;
const districtId = parseInt(obvod);
const candidateNumber = parseInt(kandidat);
const district = getDistrict(districtId);
const candidate = district?.candidates.find((c) => c.candidateNumber === candidateNumber);

if (!candidate || !district) return Astro.redirect('/');

const base = import.meta.env.BASE_URL;

const round2Candidates = district.candidates.filter((c) => c.round2Votes > 0);
const winner = round2Candidates.length > 0
  ? round2Candidates.sort((a, b) => b.round2Votes - a.round2Votes)[0]
  : null;
const isWinner = winner?.candidateNumber === candidate.candidateNumber;
const hasResults = district.candidates.some((c) => c.round1Votes > 0);
---
<Layout title={candidate.name} description={`${candidate.name} – kandidát v obvodu ${district.id} ${district.name}`}>
  <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
    <a href={base} class="hover:text-gray-900 transition-colors">Přehled obvodů</a>
    <span>›</span>
    <a href={`${base}obvod/${district.id}/`} class="hover:text-gray-900 transition-colors">
      Obvod {district.id} – {district.name}
    </a>
  </nav>

  <div class="mb-8">
    <div class="flex items-start gap-4">
      <div class="shrink-0 mt-1">
        <div class="w-14 h-14 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center text-xl font-bold text-gray-400">
          {candidate.candidateNumber}
        </div>
      </div>
      <div>
        <div class="flex items-center gap-2 flex-wrap">
          <h1 class="text-3xl font-bold text-gray-900">{candidate.name}</h1>
          {isWinner && (
            <span class="text-sm bg-gray-200 text-gray-700 px-2 py-0.5 rounded-full font-medium">Zvolený senátor</span>
          )}
        </div>
        <p class="text-gray-500 mt-1">
          Obvod {district.id} · {district.name}
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <section class="border border-gray-200 rounded-lg p-5">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Základní informace</h2>
      <dl class="space-y-3">
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Věk</dt>
          <dd class="text-sm font-medium text-gray-900">{candidate.age} let</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Volební strana</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">{candidate.electoralParty}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Politická příslušnost</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">{candidate.politicalAffiliation}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Povolání</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">{candidate.occupation}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-sm text-gray-500">Bydliště</dt>
          <dd class="text-sm font-medium text-gray-900 text-right">{candidate.residence}</dd>
        </div>
      </dl>
    </section>

    {hasResults && (
      <section class="border border-gray-200 rounded-lg p-5">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Výsledky voleb</h2>
        <dl class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <dt class="text-gray-500">1. kolo</dt>
              <dd class="font-medium text-gray-900">{candidate.round1Percent.toFixed(2).replace('.', ',')} % ({candidate.round1Votes.toLocaleString('cs')} hl.)</dd>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-gray-400 rounded-full" style={`width: ${Math.min(candidate.round1Percent, 100)}%`} />
            </div>
          </div>
          {candidate.round2Votes > 0 && (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <dt class="text-gray-500">2. kolo</dt>
                <dd class="font-medium text-gray-900">{candidate.round2Percent.toFixed(2).replace('.', ',')} % ({candidate.round2Votes.toLocaleString('cs')} hl.)</dd>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-gray-700 rounded-full" style={`width: ${Math.min(candidate.round2Percent, 100)}%`} />
              </div>
            </div>
          )}
        </dl>
      </section>
    )}
  </div>

  <section class="border border-gray-200 rounded-lg p-5 mb-6">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Zapojte se do kampaně</h2>
    <p class="text-sm text-gray-600 mb-4">
      Chcete podpořit kandidáta {candidate.name}? Existuje několik způsobů, jak se zapojit:
    </p>
    <ul class="space-y-2 text-sm text-gray-700">
      <li class="flex items-start gap-2">
        <span class="text-gray-400 mt-0.5">→</span>
        <span>Dobrovolnictví při volební kampani – distribuce letáků, organizace akcí</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-gray-400 mt-0.5">→</span>
        <span>Šíření informací o kandidátovi ve vašem okolí</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-gray-400 mt-0.5">→</span>
        <span>Finanční podpora volební kampaně</span>
      </li>
    </ul>
    <p class="text-xs text-gray-400 mt-4">Kontaktní informace budou brzy doplněny.</p>
  </section>

  <section class="border border-gray-200 rounded-lg p-5">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Otázky kandidátovi</h2>
    <div class="space-y-4">
      <div>
        <p class="text-sm font-medium text-gray-700 mb-1">Jaká je vaše motivace ke kandidatuře?</p>
        <p class="text-sm text-gray-400 italic">Odpověď bude brzy doplněna.</p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-700 mb-1">Kde vidíte republiku za 6 let?</p>
        <p class="text-sm text-gray-400 italic">Odpověď bude brzy doplněna.</p>
      </div>
    </div>
  </section>
</Layout>
