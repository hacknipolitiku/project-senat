---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { districtSlug, formatCzechName, getPartyLogoFiles } from "../../lib/data";
import { getCandidateUrl, getHomepageUrl, getPartyLogoUrl } from "../../lib/links";

export async function getStaticPaths() {
  const [districtEntries, candidateEntries] = await Promise.all([
    getCollection("districts"),
    getCollection("candidates"),
  ]);
  return districtEntries.map((district) => ({
    params: { obvod: district.data.slug },
    props: {
      district: {
        id: district.data.id,
        name: district.data.name,
        candidates: candidateEntries
          .filter((e) => e.data.districtId === district.data.id)
          .sort((a, b) => a.data.candidateNumber - b.data.candidateNumber),
      },
    },
  }));
}

const { district } = Astro.props;
---

<Layout
  title={`Obvod ${district.id} – ${district.name}`}
  description={`Kandidáti v obvodu ${district.id} ${district.name}`}
>
  <nav class="text-sm mb-6">
    <a
      href={getHomepageUrl()}
      class="font-semibold transition-opacity hover:opacity-70"
      style="color: #2a2b66;">← Přehled obvodů</a
    >
  </nav>

  <div class="mb-8">
    <div class="flex items-center gap-3 mb-1">
      <span
        class="inline-flex items-center justify-center w-10 h-10 rounded-full text-sm font-bold"
        style="background-color: #2a2b66; color: white; border: 2px solid #fa1a5b;"
      >
        {district.id}
      </span>
      <h1 class="text-3xl font-bold" style="color: #2a2b66;">
        {district.name}
      </h1>
    </div>
    <p class="text-gray-500 ml-13">{district.candidates.length} kandidátů</p>
  </div>

  <div class="grid gap-3">
    {
      district.candidates.map((c) => {
        const winner =
          district.candidates.filter((x) => x.data.round2Votes > 0).length > 0
            ? district.candidates
                .filter((x) => x.data.round2Votes > 0)
                .sort((a, b) => b.data.round2Votes - a.data.round2Votes)[0]
                ?.data.candidateNumber === c.data.candidateNumber
            : false;
        return (
          <a
            href={getCandidateUrl(c.id)}
            class="block rounded-lg px-4 py-3 transition-colors hover:bg-blue-50 border-1 border-blue-900"
          >
            <div class="flex items-start gap-4">
              <div class="w-6 text-center">
                <span class="text-xs text-gray-400 font-mono">
                  #{c.data.candidateNumber}
                </span>
              </div>
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-semibold text-gray-900">
                    {formatCzechName(c.data.name)}
                  </span>
                  {getPartyLogoFiles(c.data.electoralParty).length > 0 ? (
                    getPartyLogoFiles(c.data.electoralParty).map((logo) => (
                      <img
                        src={getPartyLogoUrl(logo)}
                        alt={logo.replace(".svg", "")}
                        class="h-5 w-auto"
                      />
                    ))
                  ) : (
                    <span>{c.data.electoralParty}</span>
                  )}
                </div>
                <div class="mt-1 text-sm text-gray-500 flex flex-wrap items-center gap-x-3 gap-y-0.5">
                  <span>{c.data.occupation}</span>
                  <span>·</span>
                  <span>{c.data.residence}</span>
                </div>
              </div>

              <div class="ml-auto w-2 h-2 border-t-1 border-l-1 transform rotate-135 border-gray-800 self-center" />
            </div>
          </a>
        );
      })
    }
  </div>

  <!-- The back button on bottom is only visible on mobile -->
  <nav class="text-sm mb-6 mt-12 sm:hidden">
    <a
      href={getHomepageUrl()}
      class="font-semibold transition-opacity hover:opacity-70"
      style="color: #2a2b66;">← Přehled obvodů</a
    >
  </nav>
</Layout>
